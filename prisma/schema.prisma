generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  ARCHIVED
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  PROSPECT
  ARCHIVED
}

enum LeadStatus {
  OPEN
  QUALIFIED
  DISQUALIFIED
  CONVERTED
  LOST
}

enum LeadSource {
  WEBSITE
  REFERRAL
  WHATSAPP
  PHONE
  EMAIL
  SOCIAL
  EVENT
  MANUAL
}

enum LeadTemperature {
  COLD
  WARM
  HOT
}

enum DealStatus {
  OPEN
  WON
  LOST
  ABANDONED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  TASK
  STATUS_CHANGE
  STAGE_CHANGE
  COMMENT
  SYSTEM
}

enum PipelineEntityType {
  LEAD
  DEAL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  ASSIGN_ROLE
  REMOVE_ROLE
}

model User {
  id                 String             @id @default(uuid()) @db.Uuid
  email              String             @unique
  name               String?
  emailVerified      DateTime?
  image              String?
  firstName          String
  lastName           String
  passwordHash       String
  avatarUrl          String?
  timezone           String             @default("Europe/Istanbul")
  locale             String             @default("tr-TR")
  status             UserStatus         @default(ACTIVE)
  lastLoginAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  archivedAt         DateTime?
  roles              UserRole[]
  ownedCompanies     Company[]          @relation("CompanyOwner")
  ownedContacts      Contact[]          @relation("ContactOwner")
  ownedLeads         Lead[]             @relation("LeadOwner")
  ownedDeals         Deal[]             @relation("DealOwner")
  assignedTasks      Task[]             @relation("TaskAssignee")
  createdTasks       Task[]             @relation("TaskCreator")
  activities         Activity[]         @relation("ActivityActor")
  notes              Note[]             @relation("NoteAuthor")
  createdPipelines   Pipeline[]         @relation("PipelineCreator")
  createdStages      Stage[]            @relation("StageCreator")
  accounts           Account[]
  sessions           Session[]
  auditLogs          AuditLog[]         @relation("AuditActor")
  dealStageHistories DealStageHistory[] @relation("DealStageHistoryActor")
  dealValueHistories DealValueHistory[] @relation("DealValueHistoryActor")

  @@index([status])
  @@index([lastLoginAt])
}

model Role {
  id          String     @id @default(uuid()) @db.Uuid
  name        String
  slug        String     @unique
  description String?
  isSystem    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  users       UserRole[]

  @@index([isSystem])
}

model UserRole {
  userId     String   @db.Uuid
  roleId     String   @db.Uuid
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model Company {
  id            String        @id @default(uuid()) @db.Uuid
  name          String
  legalName     String?
  slug          String?       @unique
  taxNumber     String?
  website       String?
  email         String?
  phone         String?
  industry      String?
  employeeCount Int?
  status        CompanyStatus @default(ACTIVE)
  country       String?
  city          String?
  addressLine1  String?
  addressLine2  String?
  postalCode    String?
  ownerId       String?       @db.Uuid
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  archivedAt    DateTime?
  owner         User?         @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  contacts      Contact[]
  leads         Lead[]
  deals         Deal[]
  tasks         Task[]
  activities    Activity[]
  notes         Note[]
  tags          Tag[]

  @@index([name])
  @@index([ownerId])
  @@index([status])
  @@index([city])
}

model Contact {
  id          String     @id @default(uuid()) @db.Uuid
  companyId   String?    @db.Uuid
  ownerId     String?    @db.Uuid
  firstName   String
  lastName    String
  jobTitle    String?
  email       String?
  phone       String?
  mobilePhone String?
  isPrimary   Boolean    @default(false)
  linkedinUrl String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  archivedAt  DateTime?
  company     Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  owner       User?      @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  leads       Lead[]
  deals       Deal[]
  tasks       Task[]
  activities  Activity[]
  notes       Note[]
  tags        Tag[]

  @@index([companyId])
  @@index([ownerId])
  @@index([email])
  @@index([lastName, firstName])
}

model Pipeline {
  id          String             @id @default(uuid()) @db.Uuid
  name        String
  key         String             @unique
  description String?
  entityType  PipelineEntityType
  isDefault   Boolean            @default(false)
  createdById String?            @db.Uuid
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  archivedAt  DateTime?
  createdBy   User?              @relation("PipelineCreator", fields: [createdById], references: [id], onDelete: SetNull)
  stages      Stage[]
  leads       Lead[]
  deals       Deal[]
  moveHistory DealStageHistory[] @relation("ToPipelineHistory")
  fromHistory DealStageHistory[] @relation("FromPipelineHistory")

  @@index([entityType])
  @@index([isDefault])
}

model Stage {
  id             String             @id @default(uuid()) @db.Uuid
  pipelineId     String             @db.Uuid
  createdById    String?            @db.Uuid
  name           String
  key            String
  position       Int
  probability    Int                @default(0)
  colorHex       String?
  isClosed       Boolean            @default(false)
  isWon          Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  pipeline       Pipeline           @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  createdBy      User?              @relation("StageCreator", fields: [createdById], references: [id], onDelete: SetNull)
  leads          Lead[]
  deals          Deal[]
  enteredHistory DealStageHistory[] @relation("ToStageHistory")
  exitedHistory  DealStageHistory[] @relation("FromStageHistory")

  @@unique([pipelineId, name])
  @@unique([pipelineId, key])
  @@unique([pipelineId, position])
  @@unique([id, pipelineId])
  @@index([pipelineId, isClosed])
}

model Lead {
  id              String          @id @default(uuid()) @db.Uuid
  companyId       String?         @db.Uuid
  contactId       String?         @db.Uuid
  ownerId         String?         @db.Uuid
  pipelineId      String          @db.Uuid
  stageId         String          @db.Uuid
  title           String
  description     String?
  email           String?
  phone           String?
  status          LeadStatus      @default(OPEN)
  source          LeadSource      @default(MANUAL)
  temperature     LeadTemperature @default(COLD)
  estimatedValue  Decimal?        @db.Decimal(18, 2)
  currency        String          @default("TRY")
  expectedCloseAt DateTime?
  qualifiedAt     DateTime?
  convertedAt     DateTime?
  lostAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  archivedAt      DateTime?
  company         Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact         Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  owner           User?           @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  pipeline        Pipeline        @relation(fields: [pipelineId], references: [id], onDelete: Restrict)
  stage           Stage           @relation(fields: [stageId, pipelineId], references: [id, pipelineId], onDelete: Restrict)
  tasks           Task[]
  activities      Activity[]
  notes           Note[]

  @@index([ownerId])
  @@index([companyId])
  @@index([contactId])
  @@index([pipelineId, stageId])
  @@index([status, source])
  @@index([expectedCloseAt])
}

model Deal {
  id              String             @id @default(uuid()) @db.Uuid
  companyId       String?            @db.Uuid
  contactId       String?            @db.Uuid
  ownerId         String?            @db.Uuid
  pipelineId      String             @db.Uuid
  stageId         String             @db.Uuid
  title           String
  description     String?
  status          DealStatus         @default(OPEN)
  amount          Decimal            @db.Decimal(18, 2)
  currency        String             @default("TRY")
  probability     Int                @default(0)
  expectedCloseAt DateTime?
  closedAt        DateTime?
  wonAt           DateTime?
  lostAt          DateTime?
  lostReason      String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  archivedAt      DateTime?
  company         Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact         Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  owner           User?              @relation("DealOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  pipeline        Pipeline           @relation(fields: [pipelineId], references: [id], onDelete: Restrict)
  stage           Stage              @relation(fields: [stageId, pipelineId], references: [id, pipelineId], onDelete: Restrict)
  tasks           Task[]
  activities      Activity[]
  notes           Note[]
  stageHistory    DealStageHistory[]
  valueHistory    DealValueHistory[]
  tags            Tag[]

  @@index([ownerId])
  @@index([companyId])
  @@index([contactId])
  @@index([pipelineId, stageId])
  @@index([status])
  @@index([expectedCloseAt])
}

model DealStageHistory {
  id             String    @id @default(uuid()) @db.Uuid
  dealId         String    @db.Uuid
  actorId        String?   @db.Uuid
  fromPipelineId String?   @db.Uuid
  toPipelineId   String    @db.Uuid
  fromStageId    String?   @db.Uuid
  toStageId      String    @db.Uuid
  movedAt        DateTime  @default(now())
  amountSnapshot Decimal   @db.Decimal(18, 2)
  currency       String
  note           String?
  deal           Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  actor          User?     @relation("DealStageHistoryActor", fields: [actorId], references: [id], onDelete: SetNull)
  fromPipeline   Pipeline? @relation("FromPipelineHistory", fields: [fromPipelineId], references: [id], onDelete: SetNull)
  toPipeline     Pipeline  @relation("ToPipelineHistory", fields: [toPipelineId], references: [id], onDelete: Cascade)
  fromStage      Stage?    @relation("FromStageHistory", fields: [fromStageId], references: [id], onDelete: SetNull)
  toStage        Stage     @relation("ToStageHistory", fields: [toStageId], references: [id], onDelete: Cascade)

  @@index([dealId, movedAt])
  @@index([toPipelineId, toStageId, movedAt])
}

model DealValueHistory {
  id            String   @id @default(uuid()) @db.Uuid
  dealId        String   @db.Uuid
  actorId       String?  @db.Uuid
  previousValue Decimal? @db.Decimal(18, 2)
  newValue      Decimal  @db.Decimal(18, 2)
  currency      String
  changedAt     DateTime @default(now())
  reason        String?
  deal          Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  actor         User?    @relation("DealValueHistoryActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([dealId, changedAt])
}

model Task {
  id          String       @id @default(uuid()) @db.Uuid
  companyId   String?      @db.Uuid
  contactId   String?      @db.Uuid
  leadId      String?      @db.Uuid
  dealId      String?      @db.Uuid
  assigneeId  String?      @db.Uuid
  creatorId   String?      @db.Uuid
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  archivedAt  DateTime?
  company     Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  deal        Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator     User?        @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  activities  Activity[]
  notes       Note[]

  @@index([assigneeId, status])
  @@index([creatorId])
  @@index([companyId])
  @@index([contactId])
  @@index([leadId])
  @@index([dealId])
  @@index([dueAt])
}

model Activity {
  id          String       @id @default(uuid()) @db.Uuid
  actorId     String?      @db.Uuid
  companyId   String?      @db.Uuid
  contactId   String?      @db.Uuid
  leadId      String?      @db.Uuid
  dealId      String?      @db.Uuid
  taskId      String?      @db.Uuid
  type        ActivityType
  subject     String
  description String?
  metadata    Json?
  occurredAt  DateTime     @default(now())
  createdAt   DateTime     @default(now())
  actor       User?        @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  company     Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  deal        Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  task        Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([actorId, occurredAt])
  @@index([companyId, occurredAt])
  @@index([contactId, occurredAt])
  @@index([leadId, occurredAt])
  @@index([dealId, occurredAt])
  @@index([taskId, occurredAt])
  @@index([type, occurredAt])
}

model Note {
  id        String   @id @default(uuid()) @db.Uuid
  authorId  String?  @db.Uuid
  companyId String?  @db.Uuid
  contactId String?  @db.Uuid
  leadId    String?  @db.Uuid
  dealId    String?  @db.Uuid
  taskId    String?  @db.Uuid
  title     String?
  body      String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User?    @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([authorId, createdAt])
  @@index([companyId, createdAt])
  @@index([contactId, createdAt])
  @@index([leadId, createdAt])
  @@index([dealId, createdAt])
  @@index([taskId, createdAt])
  @@index([isPinned, createdAt])
}

model Session {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  sessionToken String @unique
  expires    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastSeenAt DateTime @default(now())
  ipAddress  String?
  userAgent  String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expires])
  @@index([expires])
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Tag {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique
  color     String    @default("#6366f1")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  contacts  Contact[]
  companies Company[]
  deals     Deal[]

  @@index([name])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  actorId    String?     @db.Uuid
  action     AuditAction
  entityType String
  entityId   String?
  summary    String
  metadata   Json?
  createdAt  DateTime    @default(now())
  actor      User?       @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([action, createdAt])
}
